# Zapret2 VPN Configuration
# This file is used for auto-switch mode (WiFi → Zapret2, Mobile → VPN)
# Copy to /data/local/tmp/zapret2-vpn-config.env to preserve across updates

################################################################################
# ENABLE/DISABLE
################################################################################

# Enable VPN functionality (0 = disable, 1 = enable)
VPN_ENABLED=0

# Enable auto-switch mode (0 = standard mode, 1 = auto-switch between WiFi/Mobile)
AUTO_SWITCH=0

################################################################################
# SUBSCRIPTION
################################################################################

# Subscription URL (base64 encoded or plain JSON)
# Example: https://example.com/api/v1/client/subscribe?token=xxx
VPN_SUBSCRIPTION_URL=""

################################################################################
# DIRECT CONFIG (alternative to subscription)
################################################################################

# Protocol: vless, ss, vmess, trojan
VPN_PROTOCOL="vless"

# Server address
VPN_SERVER=""

# Server port
VPN_PORT=443

# For VLESS
VLESS_UUID=""
VLESS_FLOW="xtls-rprx-vision"
VLESS_SNI=""

# For ShadowSocks
SS_METHOD="aes-256-gcm"
SS_PASSWORD=""

# For VMess
VMESS_UUID=""
VMESS alterId="0"

# For Trojan
TROJAN_PASSWORD=""

################################################################################
# ROUTING OPTIONS
################################################################################

# Bypass VPN for these domains (comma-separated)
BYPASS_DOMAINS=""

# Force VPN for these domains
FORCE_VPN_DOMAINS=""

################################################################################
# BEHAVIOR
################################################################################

# Start VPN on boot (when auto-switch is enabled)
VPN_AUTOSTART=1

# Kill switch - block traffic if VPN disconnects
KILL_SWITCH=0

# Logging level: debug, info, warn, error, none
VPN_LOG_LEVEL="warn"
